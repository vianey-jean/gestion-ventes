{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://server-gestion-ventes.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://server-gestion-ventes.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads|assets|favicon).*)",
      "destination": "/index.html"
    }
  ]
}
